---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="About" description="About the Wessex Whisky Blog and the person writing it">
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-wessex-gold-50 to-wessex-red-50 py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-wessex-navy-900 mb-4 font-serif">
        About the Blog
      </h1>
      <p class="text-xl text-slate-700 max-w-3xl mx-auto">
        A personal whisky journal capturing tastings, distillery visits, and the bottles that keep me curious.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-4 text-lg text-slate-700">
        <h2 class="text-3xl font-bold text-wessex-navy-900 mb-4 font-serif">Why write about whisky?</h2>
        <p>
          I started Wessex Whisky Blog to keep track of the drams I was tasting at home and on travels. The notes were
          scattered across notebooks and phone memos, so this site became a single place to log flavours, favourites,
          and stockists worth sharing.
        </p>
        <p>
          There are no events or memberships here — just honest impressions, photos from distillery visits, and links
          to where I buy bottles. If a link is an affiliate link, I mark it clearly. The aim is simple: help other
          whisky fans find something new to enjoy.
        </p>
        <p>
          Most tastings happen in the South West, but the bottles range far wider. Expect Highland classics, Islay peat,
          Irish discoveries, and the occasional world whisky that surprises me.
        </p>
      </div>
      <div class="relative">
        <div class="aspect-w-4 aspect-h-3 rounded-lg overflow-hidden bg-slate-200 flex items-center justify-center p-8">
          <img src="/wessex_whisky_logo_coloured.png" alt="Wessex Whisky Blog" class="max-w-full max-h-full object-contain" />
        </div>
      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
          <h3 class="text-xl font-semibold text-wessex-navy-900 mb-3">Tasting notes</h3>
          <p class="text-slate-700 text-sm">
            Nose, palate, finish and an overall impression on bottles I buy, share, or taste at friends' tables.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
          <h3 class="text-xl font-semibold text-wessex-navy-900 mb-3">Distillery visits</h3>
          <p class="text-slate-700 text-sm">
            Snapshots from tours across the UK and beyond: what stood out, which drams to seek out, and photos along the way.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
          <h3 class="text-xl font-semibold text-wessex-navy-900 mb-3">Stockists</h3>
          <p class="text-slate-700 text-sm">
            Links to reliable shops. Affiliate links are labelled so you know when a click supports the blog.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-16 bg-wessex-red-500">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h2 class="text-3xl font-bold mb-4 font-serif">Want to say hello?</h2>
      <p class="text-lg text-wessex-red-100 mb-8">
        Drop a note if you'd like me to taste something specific or have a distillery tip to share.
      </p>
      <a href="/contact" class="inline-flex items-center bg-white text-wessex-red-500 px-8 py-3 rounded-lg font-semibold hover:bg-wessex-red-50 transition-colors">
        Get in touch
      </a>
    </div>
  </section>
</MainLayout>

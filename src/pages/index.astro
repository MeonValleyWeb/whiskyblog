---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';

let recentPosts = await getCollection('posts');
recentPosts = recentPosts.sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));
---

<MainLayout title="Home" description="Wessex Whisky Blog - personal whisky notes, distillery visits and stockist recommendations">
  
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-wessex-gold-50 to-wessex-red-50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-6xl font-bold text-wessex-navy-900 mb-6 font-serif">
          Wessex Whisky Blog
          <span class="block text-wessex-red-500">Personal tasting notes, distillery visits and reviews</span>
        </h1>
        <p class="text-xl text-slate-700 mb-8 max-w-3xl mx-auto">
          A personal journal of drams I've enjoyed, with tasting notes, distillery stories and links to trusted stockists (affiliate links marked).
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/blog" class="bg-wessex-red-500 text-white px-8 py-3 rounded-lg hover:bg-wessex-red-600 transition-colors font-semibold text-lg">
            Read the blog
          </a>
          <a href="/subscribe" class="border-2 border-wessex-red-500 text-wessex-red-500 px-8 py-3 rounded-lg hover:bg-wessex-red-50 transition-colors font-semibold text-lg">
            Get updates
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent Blog Posts -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-wessex-navy-900 mb-4 font-serif">Recent Posts</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">Latest tasting notes, reviews and distillery visits.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {recentPosts.slice(0, 6).map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-wessex-navy-900 mb-6 font-serif">
            Personal Whisky Writing
          </h2>
          <p class="text-lg text-slate-700 mb-6">
            This blog collects tasting notes, reviews, distillery visit write-ups and recommended stockists. Use tags to find tasting-note style posts or look up distillery pages for deeper reads.
        </p>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center text-slate-700">Straightforward tasting notes on bottles I buy or try</li>
          <li class="flex items-center text-slate-700">Distillery visits, background reading and travel notes</li>
          <li class="flex items-center text-slate-700">Stockists and affiliate links clearly labelled</li>
        </ul>
        <a href="/blog" class="inline-flex items-center text-amber-600 hover:text-amber-700 font-semibold">
          Browse the blog
            <svg class="w-5 h-5 ml-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>
        <div class="relative">
          <div class="aspect-w-4 aspect-h-3 rounded-lg overflow-hidden bg-slate-200">
            <img src="/images/tasting.jpg" alt="Tasting notes" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Transparency Section -->
  <section class="py-14 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-wessex-navy-900 mb-4 font-serif">Affiliate transparency</h2>
      <p class="text-lg text-slate-600">
        Some stockist links are affiliate links. They never change the price you pay and they help fund more tasting notes. I mark them clearly throughout the site.
      </p>
    </div>
  </section>
</MainLayout>

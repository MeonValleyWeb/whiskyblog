---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const featuredTastings = await getCollection('tastings', ({ data }) => {
  return data.featured === true;
});

const upcomingTastings = await getCollection('tastings', ({ data }) => {
  return new Date(data.date) > new Date();
});

const recentPosts = await getCollection('posts');
---

<MainLayout title="Home" description="Wessex Whisky Club - Premium whisky tastings supporting local charities in the South West">
  
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-amber-50 to-orange-50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-6xl font-bold text-slate-900 mb-6">
          Premium Whisky Tastings
          <span class="block text-amber-600">For Charity</span>
        </h1>
        <p class="text-xl text-slate-700 mb-8 max-w-3xl mx-auto">
          Join Wessex Whisky Club for exceptional whisky experiences while supporting local charities across the South West. 
          Every tasting makes a difference.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/membership" class="bg-amber-600 text-white px-8 py-3 rounded-lg hover:bg-amber-700 transition-colors font-semibold text-lg">
            Become a Member
          </a>
          <a href="/tastings" class="border-2 border-amber-600 text-amber-600 px-8 py-3 rounded-lg hover:bg-amber-50 transition-colors font-semibold text-lg">
            View Tastings
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Tastings -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Upcoming Tastings</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Experience premium whiskies from renowned distilleries while supporting worthy causes
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {upcomingTastings.slice(0, 3).map((tasting) => (
          <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow border border-slate-200">
            {tasting.data.image && (
              <img src={tasting.data.image} alt={tasting.data.title} class="w-full h-48 object-cover rounded-t-lg" />
            )}
            <div class="p-6">
              <div class="flex justify-between items-start mb-3">
                <h3 class="text-xl font-semibold text-slate-900">{tasting.data.title}</h3>
                <span class="text-sm text-amber-600 font-medium">
                  {tasting.data.date.toLocaleDateString('en-GB', { 
                    day: 'numeric', 
                    month: 'short' 
                  })}
                </span>
              </div>
              <p class="text-slate-600 mb-4 line-clamp-3">{tasting.data.description}</p>
              <div class="flex justify-between items-center mb-4">
                <div class="text-sm text-slate-500">
                  <p>{tasting.data.location}</p>
                  <p>{tasting.data.time}</p>
                </div>
                <div class="text-right">
                  <p class="text-lg font-semibold text-slate-900">£{tasting.data.memberPrice}</p>
                  <p class="text-sm text-slate-500">members</p>
                </div>
              </div>
              <a href={`/tastings/${tasting.slug}`} class="block w-full text-center bg-amber-600 text-white py-2 rounded-lg hover:bg-amber-700 transition-colors font-medium">
                Book Now
              </a>
            </div>
          </div>
        ))}
      </div>

      {upcomingTastings.length === 0 && (
        <div class="text-center py-12">
          <p class="text-slate-600 text-lg">New tastings coming soon! Check back regularly or join our mailing list for updates.</p>
        </div>
      )}
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">
            Exceptional Whiskies,
            <span class="text-amber-600">Exceptional Causes</span>
          </h2>
          <p class="text-lg text-slate-700 mb-6">
            At Wessex Whisky Club, we believe great whisky should serve a greater purpose. We partner with 
            renowned distilleries to bring you exclusive tastings, with all proceeds supporting carefully 
            selected local charities.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-center text-slate-700">
              <svg class="w-5 h-5 text-amber-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Premium whisky tastings from top distilleries
            </li>
            <li class="flex items-center text-slate-700">
              <svg class="w-5 h-5 text-amber-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              100% of proceeds support local charities
            </li>
            <li class="flex items-center text-slate-700">
              <svg class="w-5 h-5 text-amber-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Exclusive member pricing and early access
            </li>
            <li class="flex items-center text-slate-700">
              <svg class="w-5 h-5 text-amber-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Expert-led educational experiences
            </li>
          </ul>
          <a href="/about" class="inline-flex items-center text-amber-600 hover:text-amber-700 font-semibold">
            Learn more about us 
            <svg class="w-5 h-5 ml-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>
        <div class="relative">
          <div class="aspect-w-4 aspect-h-3 rounded-lg overflow-hidden bg-slate-200">
            <!-- Placeholder for image -->
            <div class="flex items-center justify-center text-slate-500">
              <span>Tasting Event Photo</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-amber-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Join Our Community?
      </h2>
      <p class="text-xl text-amber-100 mb-8 max-w-2xl mx-auto">
        Become a member today and enjoy exclusive access to premium tastings at member prices, 
        while supporting great causes in your community.
      </p>
      <a href="/membership" class="inline-block bg-white text-amber-600 px-8 py-3 rounded-lg hover:bg-amber-50 transition-colors font-semibold text-lg">
        Join Wessex Whisky Club
      </a>
    </div>
  </section>

</MainLayout>

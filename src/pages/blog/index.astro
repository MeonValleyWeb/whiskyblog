---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';

const posts = await getCollection('posts');
posts.sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));
---

<MainLayout title="Blog">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold text-wessex-navy-800 font-serif">Tasting Notes & Blog</h1>
      <p class="text-slate-600 mt-2 max-w-3xl">
        Personal whisky journal: tastings, distillery visits, stockists and recommendations. Affiliate links are marked so you know when a click helps fund more drams.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</MainLayout>

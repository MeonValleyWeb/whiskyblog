---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contact" description="Contact the Wessex Whisky Blog">
  
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-wessex-gold-50 to-wessex-red-50 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-wessex-navy-900 mb-6 font-serif">
        Say hello
      </h1>
      <p class="text-xl text-slate-700">
        Send tasting tips, bottle recommendations, or notes on a distillery I should visit next.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-1 space-y-6">
          <div class="p-6 bg-slate-50 rounded-lg border border-slate-200">
            <h2 class="text-xl font-semibold text-wessex-navy-900 mb-3">Contact details</h2>
            <p class="text-slate-700 text-sm">hello@wessexwhisky.co.uk</p>
            <p class="text-slate-600 text-sm mt-2">Based in the South West. Expect replies within a day or two.</p>
          </div>
          <div class="p-6 bg-slate-50 rounded-lg border border-slate-200">
            <h3 class="text-lg font-semibold text-wessex-navy-900 mb-2">Social</h3>
            <p class="text-slate-700 text-sm">Instagram and Facebook links will live here once they're set up.</p>
          </div>
        </div>

        <div class="lg:col-span-2">
          <div class="bg-slate-50 rounded-lg p-8 border border-slate-200">
            <h3 class="text-2xl font-bold text-slate-900 mb-6">Send a message</h3>
            
            <form class="space-y-6">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="firstName" class="block text-sm font-medium text-slate-700 mb-1">
                    First name
                  </label>
                  <input 
                    type="text" 
                    id="firstName" 
                    name="firstName" 
                    class="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                    required
                  >
                </div>
                <div>
                  <label for="lastName" class="block text-sm font-medium text-slate-700 mb-1">
                    Last name
                  </label>
                  <input 
                    type="text" 
                    id="lastName" 
                    name="lastName" 
                    class="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                    required
                  >
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-1">
                  Email address
                </label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  class="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                  required
                >
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-slate-700 mb-1">
                  Message
                </label>
                <textarea 
                  id="message" 
                  name="message" 
                  rows="4" 
                  class="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                  required
                ></textarea>
              </div>

              <div class="flex items-center">
                <input 
                  id="newsletter" 
                  name="newsletter" 
                  type="checkbox" 
                  class="h-4 w-4 text-amber-600 focus:ring-amber-500 border-slate-300 rounded"
                >
                <label for="newsletter" class="ml-2 block text-sm text-slate-700">
                  Send me tasting updates (a light, occasional newsletter).
                </label>
              </div>

              <button 
                type="submit" 
                class="w-full bg-wessex-red-500 text-white py-3 px-4 rounded-md hover:bg-wessex-red-600 focus:outline-none focus:ring-2 focus:ring-wessex-red-500 focus:ring-offset-2 transition-colors font-medium"
              >
                Send Message
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

</MainLayout>

---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection, getEntryBySlug } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const slug = Astro.params.slug;
const guide = Astro.props.guide ?? (await getEntryBySlug('guides', slug));

if (!guide) {
  throw new Error(`Guide not found: ${slug}`);
}

const { Content } = await guide.render();

// Fetch related posts if specified
const allPosts = await getCollection('posts');
const relatedPosts = guide.data.relatedPosts
  ? allPosts.filter((post) => guide.data.relatedPosts?.includes(post.slug))
  : [];

// Fetch related guides if specified
const allGuides = await getCollection('guides');
const relatedGuides = guide.data.relatedGuides
  ? allGuides.filter((g) => guide.data.relatedGuides?.includes(g.slug))
  : [];
---

<MainLayout title={guide.data.title} description={guide.data.excerpt}>
  <article class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
      {guide.data.image ? (
        <div class="relative">
          <img src={guide.data.image} alt={guide.data.title} class="w-full h-80 object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
          <div class="absolute bottom-4 left-4 right-4 text-white">
            <p class="text-sm uppercase tracking-wide">Whisky Guide</p>
            <h1 class="text-3xl md:text-4xl font-bold leading-tight">{guide.data.title}</h1>
          </div>
        </div>
      ) : (
        <div class="p-8">
          <p class="text-sm uppercase tracking-wide text-wessex-red-500">Whisky Guide</p>
          <h1 class="text-3xl md:text-4xl font-bold text-wessex-navy-900 leading-tight">{guide.data.title}</h1>
        </div>
      )}

      <div class="px-6 py-5 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div class="space-y-1">
          <p class="text-sm text-slate-500">
            {new Date(guide.data.date).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })} • {guide.data.author}
          </p>
          <p class="text-slate-700">{guide.data.excerpt}</p>
          <div class="flex flex-wrap gap-2 pt-2">
            {guide.data.tags?.map((tag) => (
              <span class="text-xs bg-wessex-gold-100 text-wessex-navy-700 px-2 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mt-10">
      <div class="lg:col-span-2 space-y-8">
        <!-- Main Content -->
        <section class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
          <div class="prose prose-slate max-w-none prose-headings:mt-8 prose-headings:mb-4 prose-hr:my-8 prose-p:mb-4 prose-ul:mt-2 prose-ul:mb-4">
            <Content />
          </div>
        </section>

        <!-- Related Guides -->
        {relatedGuides.length > 0 && (
          <section class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <h2 class="text-xl font-semibold text-wessex-navy-900 mb-4">Related Questions</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {relatedGuides.map((relatedGuide) => (
                <a
                  href={`/guides/${relatedGuide.slug}`}
                  class="p-4 rounded-lg border border-slate-200 hover:border-wessex-gold-300 hover:shadow-sm transition-colors"
                >
                  <h3 class="font-semibold text-wessex-navy-900 mb-1">{relatedGuide.data.title}</h3>
                  <p class="text-sm text-slate-600">{relatedGuide.data.excerpt}</p>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>

      <aside class="space-y-6">
        <!-- Related Tastings -->
        {relatedPosts.length > 0 ? (
          <section class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-wessex-navy-900 mb-3">Related Tastings</h2>
            <p class="text-sm text-slate-600 mb-4">Explore these tasting notes that complement this guide.</p>
            <div class="space-y-3">
              {relatedPosts.map((post) => (
                <a
                  href={`/blog/${post.slug}`}
                  class="block p-3 rounded-lg border border-slate-200 hover:border-wessex-red-300 hover:shadow-sm transition-colors"
                >
                  <p class="font-semibold text-wessex-navy-800 mb-1">{post.data.title}</p>
                  <p class="text-xs text-slate-600">{post.data.distillery ?? 'Tasting Notes'}</p>
                  {post.data.rating !== undefined && (
                    <div class="mt-2 text-xs font-semibold text-wessex-navy-800 bg-wessex-gold-50 border border-wessex-gold-200 px-2 py-1 rounded-full inline-block">
                      {post.data.rating}/5
                    </div>
                  )}
                </a>
              ))}
            </div>
          </section>
        ) : (
          <section class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-wessex-navy-900 mb-2">Related Tastings</h2>
            <p class="text-sm text-slate-600">Check out our tasting notes for whisky recommendations.</p>
            <a href="/blog" class="inline-block mt-3 text-sm font-semibold text-wessex-red-600 hover:text-wessex-red-700">
              Browse Tastings →
            </a>
          </section>
        )}

        <!-- About This Guide -->
        <section class="bg-wessex-gold-50 border border-wessex-gold-200 rounded-xl p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-wessex-navy-900 mb-2">About This Guide</h2>
          <div class="space-y-2 text-sm text-slate-700">
            {guide.data.searchVolume !== undefined && (
              <p>
                <span class="font-semibold">Search Interest:</span> {guide.data.searchVolume} monthly searches
              </p>
            )}
            {guide.data.keyword && (
              <p>
                <span class="font-semibold">Topic:</span> {guide.data.keyword}
              </p>
            )}
            <p class="text-xs text-slate-500 pt-2">
              Last updated: {new Date(guide.data.date).toLocaleDateString(undefined, { month: 'long', year: 'numeric' })}
            </p>
          </div>
        </section>

        <!-- Subscribe CTA -->
        <section class="bg-wessex-red-500 rounded-xl p-6 shadow-sm text-white">
          <h2 class="text-lg font-semibold mb-2 font-serif">Subscribe for More Guides</h2>
          <p class="text-sm text-wessex-red-100 mb-4">
            Get whisky guides and tasting notes delivered to your inbox.
          </p>
          <a href="/subscribe" class="inline-flex items-center justify-center w-full bg-white text-wessex-red-500 px-4 py-2 rounded-lg font-semibold hover:bg-wessex-red-50 transition-colors">
            Subscribe
          </a>
        </section>
      </aside>
    </div>
  </article>
</MainLayout>

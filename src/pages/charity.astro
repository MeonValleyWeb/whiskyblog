---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Our Charity Work" description="Learn how Wessex Whisky Club supports local charities across the South West through our whisky tasting events">
  
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-green-50 to-emerald-50 py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        Charity & Community
      </h1>
      <p class="text-xl text-slate-700">
        Every dram with purpose. Supporting local causes across the South West.
      </p>
    </div>
  </section>

  <!-- Impact Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">Our Impact</h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          Since 2018, we've raised over £50,000 for local charities through our whisky tasting events. 
          Every ticket sold contributes directly to worthy causes across the South West.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="text-center p-8 bg-green-50 rounded-lg">
          <div class="text-4xl font-bold text-green-600 mb-2">£50,000+</div>
          <div class="text-lg font-medium text-slate-900 mb-2">Total Raised</div>
          <div class="text-slate-600">Supporting local causes since 2018</div>
        </div>
        
        <div class="text-center p-8 bg-blue-50 rounded-lg">
          <div class="text-4xl font-bold text-blue-600 mb-2">25+</div>
          <div class="text-lg font-medium text-slate-900 mb-2">Charities Supported</div>
          <div class="text-slate-600">Diverse causes across the region</div>
        </div>
        
        <div class="text-center p-8 bg-amber-50 rounded-lg">
          <div class="text-4xl font-bold text-amber-600 mb-2">100%</div>
          <div class="text-lg font-medium text-slate-900 mb-2">Proceeds Donated</div>
          <div class="text-slate-600">Every penny goes to charity</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Current Charity -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-slate-900 mb-4">2024 Charity Partner</h2>
        <p class="text-lg text-slate-600">This year, we're proud to support</p>
      </div>

      <div class="bg-white rounded-lg shadow-lg p-8 md:p-12 max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div>
            <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center mx-auto md:mx-0 mb-6">
              <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
              </svg>
            </div>
          </div>
          <div class="text-center md:text-left">
            <h3 class="text-2xl font-bold text-slate-900 mb-4">Children's Hospice South West</h3>
            <p class="text-lg text-slate-700 mb-6">
              Providing vital care and support to life-limited children and their families 
              across Devon, Cornwall, and Somerset. Their work brings comfort, joy, and 
              precious memories to families during the most challenging times.
            </p>
            <a href="#" class="inline-flex items-center text-green-600 hover:text-green-700 font-semibold">
              Learn more about CHSW
              <svg class="w-5 h-5 ml-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="mt-8 p-6 bg-green-50 rounded-lg">
          <div class="text-center">
            <h4 class="text-lg font-semibold text-green-800 mb-2">2024 Progress</h4>
            <div class="text-3xl font-bold text-green-600 mb-2">£3,200</div>
            <div class="text-green-700">raised so far this year</div>
            <div class="w-full bg-green-200 rounded-full h-2 mt-4">
              <div class="bg-green-600 h-2 rounded-full" style="width: 32%"></div>
            </div>
            <div class="text-sm text-green-600 mt-2">32% of annual £10,000 target</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Past Charities -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-slate-900 mb-4">Past Partners</h2>
        <p class="text-lg text-slate-600">
          Over the years, we've been proud to support these incredible organizations
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- 2023 -->
        <div class="bg-slate-50 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-blue-600 font-semibold">2023</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">Dorset Wildlife Trust</h3>
          </div>
          <p class="text-slate-600 mb-4">
            Protected over 100 acres of vital habitat and supported conservation education programs.
          </p>
          <div class="text-lg font-semibold text-green-600">£8,400 raised</div>
        </div>

        <!-- 2022 -->
        <div class="bg-slate-50 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-purple-600 font-semibold">2022</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">Julia's House</h3>
          </div>
          <p class="text-slate-600 mb-4">
            Provided respite care and support for families with seriously ill children across Dorset.
          </p>
          <div class="text-lg font-semibold text-green-600">£7,800 raised</div>
        </div>

        <!-- 2021 -->
        <div class="bg-slate-50 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-red-600 font-semibold">2021</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">Exeter Foodbank</h3>
          </div>
          <p class="text-slate-600 mb-4">
            Supported families in crisis with emergency food parcels during the pandemic.
          </p>
          <div class="text-lg font-semibold text-green-600">£6,200 raised</div>
        </div>

        <!-- 2020 -->
        <div class="bg-slate-50 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-orange-600 font-semibold">2020</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">Mind in Somerset</h3>
          </div>
          <p class="text-slate-600 mb-4">
            Provided crucial mental health support services during challenging times.
          </p>
          <div class="text-lg font-semibold text-green-600">£5,900 raised</div>
        </div>

        <!-- 2019 -->
        <div class="bg-slate-50 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-teal-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-teal-600 font-semibold">2019</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">Cornwall Air Ambulance</h3>
          </div>
          <p class="text-slate-600 mb-4">
            Supported life-saving emergency medical services across Cornwall and the Isles of Scilly.
          </p>
          <div class="text-lg font-semibold text-green-600">£9,200 raised</div>
        </div>

        <!-- 2018 -->
        <div class="bg-slate-50 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-indigo-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-indigo-600 font-semibold">2018</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">Devon Youth Association</h3>
          </div>
          <p class="text-slate-600 mb-4">
            Funded youth programs and activities for disadvantaged young people in Devon.
          </p>
          <div class="text-lg font-semibold text-green-600">£4,500 raised</div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 bg-green-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-slate-900 mb-4">How We Make a Difference</h2>
        <p class="text-lg text-slate-600">Our simple but effective approach to charitable giving</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-green-600">1</span>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Member Nominations</h3>
          <p class="text-slate-600 text-sm">
            Club members nominate local charities that are close to their hearts
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-green-600">2</span>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Democratic Selection</h3>
          <p class="text-slate-600 text-sm">
            All members vote to select our annual charity partner
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-green-600">3</span>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Events & Fundraising</h3>
          <p class="text-slate-600 text-sm">
            Every tasting event raises funds through ticket sales
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-green-600">4</span>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Direct Donation</h3>
          <p class="text-slate-600 text-sm">
            100% of proceeds go directly to our chosen charity
          </p>
        </div>
      </div>

      <div class="text-center mt-12">
        <div class="bg-white p-6 rounded-lg shadow-sm inline-block">
          <h4 class="text-lg font-semibold text-slate-900 mb-2">Transparency Promise</h4>
          <p class="text-slate-600 max-w-md">
            We publish detailed reports of all funds raised and donated. Every penny is accounted for, 
            and members receive regular updates on our charitable impact.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Nomination Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-slate-900 mb-6">Nominate a Charity</h2>
      <p class="text-lg text-slate-600 mb-8">
        Do you know a local charity that deserves support? We're always looking for worthy causes 
        to consider for future partnerships.
      </p>
      
      <div class="bg-slate-50 p-8 rounded-lg">
        <h3 class="text-xl font-semibold text-slate-900 mb-4">Nomination Criteria</h3>
        <ul class="text-left space-y-2 max-w-2xl mx-auto mb-8">
          <li class="flex items-center">
            <svg class="w-5 h-5 text-green-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            Registered charity operating in the South West
          </li>
          <li class="flex items-center">
            <svg class="w-5 h-5 text-green-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            Direct impact on local communities
          </li>
          <li class="flex items-center">
            <svg class="w-5 h-5 text-green-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            Clear demonstration of fund usage
          </li>
          <li class="flex items-center">
            <svg class="w-5 h-5 text-green-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            Willingness to engage with our community
          </li>
        </ul>
        
        <a href="/contact" class="inline-block bg-green-600 text-white px-8 py-3 rounded-lg hover:bg-green-700 transition-colors font-semibold">
          Submit a Nomination
        </a>
      </div>
    </div>
  </section>

</MainLayout>
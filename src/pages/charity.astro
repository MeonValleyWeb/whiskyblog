---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Our Charity Work" description="Learn how Wessex Whisky Club supports local charities across the South West through our whisky tasting events">
  
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-green-50 to-emerald-50 py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-wessex-navy-900 mb-6 font-serif">
        Charity & Community
      </h1>
      <p class="text-xl text-slate-700">
        Every dram with purpose. Supporting local causes across the South.
      </p>
    </div>
  </section>

  <!-- Impact Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-wessex-navy-900 mb-6 font-serif">Our Impact</h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          Since 2011, we've raised over £10,000 in donations to various causes as a result of the generosity of our members. 
          Every ticket sold contributes directly to worthy causes across the South.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="text-center p-8 bg-wessex-gold-50 rounded-lg">
          <div class="text-4xl font-bold text-wessex-gold-600 mb-2">£10,000+</div>
          <div class="text-lg font-medium text-slate-900 mb-2">Total Raised</div>
          <div class="text-slate-600">Supporting local causes since 2011</div>
        </div>
        
        <div class="text-center p-8 bg-wessex-red-50 rounded-lg">
          <div class="text-4xl font-bold text-wessex-red-600 mb-2">12+</div>
          <div class="text-lg font-medium text-slate-900 mb-2">Charities Supported</div>
          <div class="text-slate-600">Diverse causes across the region</div>
        </div>
        
        <div class="text-center p-8 bg-wessex-navy-50 rounded-lg">
          <div class="text-4xl font-bold text-wessex-navy-600 mb-2">100%</div>
          <div class="text-lg font-medium text-slate-900 mb-2">Proceeds Donated</div>
          <div class="text-slate-600">Every penny goes to charity</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Current Charity -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-wessex-navy-900 mb-4 font-serif">2024 Charity Partner</h2>
        <p class="text-lg text-slate-600">This year, we're proud to support</p>
      </div>

      <div class="bg-white rounded-lg shadow-lg p-8 md:p-12 max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div class="text-center md:text-left">
            <img src="/images/H&IOW_Air_Ambulance.jpg" alt="Hants and IOW Air Ambulance" class="w-full max-w-sm mx-auto md:mx-0 rounded-lg shadow-md mb-6" />
          </div>
          <div class="text-center md:text-left">
            <h3 class="text-2xl font-bold text-wessex-navy-900 mb-4">Hants and IOW Air Ambulance</h3>
            <p class="text-lg text-slate-700 mb-6">
              Providing life-saving emergency medical services across Hampshire and the Isle of Wight. 
              Their highly skilled crews bring critical care directly to patients, often in situations 
              where every minute counts. Operating 365 days a year, they are a vital lifeline for our community.
            </p>
            <a href="https://www.hiowaa.org" target="_blank" class="inline-flex items-center text-red-600 hover:text-red-700 font-semibold">
              Learn more about HIOWAA
              <svg class="w-5 h-5 ml-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="mt-8 p-6 bg-red-50 rounded-lg">
          <div class="text-center">
            <h4 class="text-lg font-semibold text-red-800 mb-2">2024 Progress</h4>
            <div class="text-3xl font-bold text-red-600 mb-2">£1,200</div>
            <div class="text-red-700">raised so far this year</div>
            <div class="w-full bg-red-200 rounded-full h-2 mt-4">
              <div class="bg-red-600 h-2 rounded-full" style="width: 24%"></div>
            </div>
            <div class="text-sm text-red-600 mt-2">24% of annual £5,000 target</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Past Charities -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-wessex-navy-900 mb-4 font-serif">Past Partners</h2>
        <p class="text-lg text-slate-600">
          Over the years, we've been proud to support these incredible organizations
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- 2023 -->
        <div class="bg-slate-50 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-blue-600 font-semibold">2023</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">Winchester Hospice</h3>
          </div>
          <p class="text-slate-600 mb-4">
            Provided vital care and support for patients and families in the Winchester area.
          </p>
          <div class="text-lg font-semibold text-green-600">£1,800 raised</div>
        </div>

        <!-- 2022 -->
        <div class="bg-slate-50 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-purple-600 font-semibold">2022</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">Hampshire Wildlife Trust</h3>
          </div>
          <p class="text-slate-600 mb-4">
            Supported conservation efforts and wildlife protection across Hampshire.
          </p>
          <div class="text-lg font-semibold text-green-600">£1,500 raised</div>
        </div>

        <!-- 2021 -->
        <div class="bg-slate-50 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-red-600 font-semibold">2021</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">Winchester Foodbank</h3>
          </div>
          <p class="text-slate-600 mb-4">
            Supported families in crisis with emergency food parcels during the pandemic.
          </p>
          <div class="text-lg font-semibold text-green-600">£1,200 raised</div>
        </div>

        <!-- 2020 -->
        <div class="bg-slate-50 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-orange-600 font-semibold">2020</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">Mind in Hampshire</h3>
          </div>
          <p class="text-slate-600 mb-4">
            Provided crucial mental health support services during challenging times.
          </p>
          <div class="text-lg font-semibold text-green-600">£1,100 raised</div>
        </div>

        <!-- 2019 -->
        <div class="bg-slate-50 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-teal-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-teal-600 font-semibold">2019</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">Hants and IOW Air Ambulance</h3>
          </div>
          <p class="text-slate-600 mb-4">
            Supported life-saving emergency medical services across Hampshire and the Isle of Wight.
          </p>
          <div class="text-lg font-semibold text-green-600">£1,600 raised</div>
        </div>

        <!-- 2018 -->
        <div class="bg-slate-50 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-indigo-100 rounded-full flex items-center justify-center mr-4">
              <span class="text-indigo-600 font-semibold">2018</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">Winchester Youth Centre</h3>
          </div>
          <p class="text-slate-600 mb-4">
            Funded youth programs and activities for young people in the Winchester area.
          </p>
          <div class="text-lg font-semibold text-green-600">£900 raised</div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 bg-green-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-wessex-navy-900 mb-4 font-serif">How We Make a Difference</h2>
        <p class="text-lg text-slate-600">Our simple but effective approach to charitable giving</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-green-600">1</span>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Member Nominations</h3>
          <p class="text-slate-600 text-sm">
            Club members nominate local charities that are close to their hearts
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-green-600">2</span>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Democratic Selection</h3>
          <p class="text-slate-600 text-sm">
            All members vote to select our annual charity partner
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-green-600">3</span>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Events & Fundraising</h3>
          <p class="text-slate-600 text-sm">
            Every tasting event raises funds through ticket sales
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-green-600">4</span>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Direct Donation</h3>
          <p class="text-slate-600 text-sm">
            100% of proceeds go directly to our chosen charity
          </p>
        </div>
      </div>

      <div class="text-center mt-12">
        <div class="bg-white p-6 rounded-lg shadow-sm inline-block">
          <h4 class="text-lg font-semibold text-slate-900 mb-2">Transparency Promise</h4>
          <p class="text-slate-600 max-w-md">
            We publish detailed reports of all funds raised and donated. Every penny is accounted for, 
            and members receive regular updates on our charitable impact.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Nomination Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-wessex-navy-900 mb-6 font-serif">Nominate a Charity</h2>
      <p class="text-lg text-slate-600 mb-8">
        Do you know a local charity that deserves support? We're always looking for worthy causes 
        to consider for future partnerships.
      </p>
      
      <div class="bg-slate-50 p-8 rounded-lg">
        <h3 class="text-xl font-semibold text-slate-900 mb-4">Nomination Criteria</h3>
        <ul class="text-left space-y-2 max-w-2xl mx-auto mb-8">
          <li class="flex items-center">
            <svg class="w-5 h-5 text-green-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            Registered charity operating in the South West
          </li>
          <li class="flex items-center">
            <svg class="w-5 h-5 text-green-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            Direct impact on local communities
          </li>
          <li class="flex items-center">
            <svg class="w-5 h-5 text-green-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            Clear demonstration of fund usage
          </li>
          <li class="flex items-center">
            <svg class="w-5 h-5 text-green-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            Willingness to engage with our community
          </li>
        </ul>
        
        <a href="/contact" class="inline-block bg-wessex-red-500 text-white px-8 py-3 rounded-lg hover:bg-wessex-red-600 transition-colors font-semibold">
          Submit a Nomination
        </a>
      </div>
    </div>
  </section>

</MainLayout>
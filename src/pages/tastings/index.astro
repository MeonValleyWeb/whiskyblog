---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const allTastings = await getCollection('tastings');
const upcomingTastings = allTastings.filter(tasting => new Date(tasting.data.date) > new Date());
const pastTastings = allTastings.filter(tasting => new Date(tasting.data.date) <= new Date());

// Sort upcoming by date (earliest first)
upcomingTastings.sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

// Sort past by date (latest first)
pastTastings.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<MainLayout title="Tastings" description="Discover upcoming whisky tastings and book your spot at Wessex Whisky Club events">
  
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-wessex-gold-50 to-wessex-red-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-wessex-navy-900 mb-6 font-serif">
          Whisky Tastings
        </h1>
        <p class="text-xl text-slate-700 mb-8 max-w-3xl mx-auto">
          Join us for exceptional whisky experiences featuring premium spirits from renowned distilleries. 
          All proceeds support local charities across the South West.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#upcoming" class="bg-wessex-red-500 text-white px-8 py-3 rounded-lg hover:bg-wessex-red-600 transition-colors font-semibold">
            View Upcoming Events
          </a>
          <a href="/membership" class="border-2 border-wessex-red-500 text-wessex-red-500 px-8 py-3 rounded-lg hover:bg-wessex-red-50 transition-colors font-semibold">
            Become a Member
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Upcoming Tastings -->
  <section id="upcoming" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-wessex-navy-900 mb-4 font-serif">Upcoming Tastings</h2>
        <p class="text-lg text-slate-600">
          Book your spot at our next whisky experience
        </p>
      </div>

      {upcomingTastings.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {upcomingTastings.map((tasting) => (
            <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow border border-slate-200 overflow-hidden">
              {tasting.data.image && (
                <div class="aspect-w-16 aspect-h-9">
                  <img src={tasting.data.image} alt={tasting.data.title} class="w-full h-48 object-cover" />
                </div>
              )}
              <div class="p-6">
                <div class="flex justify-between items-start mb-3">
                  <div>
                    <h3 class="text-xl font-semibold text-slate-900 mb-1">{tasting.data.title}</h3>
                    {tasting.data.distillery && (
                      <p class="text-wessex-gold-600 font-medium text-sm">{tasting.data.distillery}</p>
                    )}
                  </div>
                  {tasting.data.featured && (
                    <span class="bg-wessex-gold-100 text-wessex-gold-800 text-xs font-semibold px-2 py-1 rounded">
                      Featured
                    </span>
                  )}
                </div>
                
                <p class="text-slate-600 mb-4 line-clamp-3">{tasting.data.description}</p>
                
                <div class="grid grid-cols-2 gap-4 mb-4 text-sm">
                  <div>
                    <div class="font-medium text-slate-700">Date & Time</div>
                    <div class="text-slate-600">
                      {tasting.data.date.toLocaleDateString('en-GB', { 
                        weekday: 'short',
                        day: 'numeric', 
                        month: 'short',
                        year: 'numeric'
                      })}
                    </div>
                    <div class="text-slate-600">{tasting.data.time}</div>
                  </div>
                  <div>
                    <div class="font-medium text-slate-700">Location</div>
                    <div class="text-slate-600">{tasting.data.location}</div>
                  </div>
                </div>

                <div class="flex justify-between items-center mb-4">
                  <div>
                    <div class="text-lg font-semibold text-slate-900">
                      £{tasting.data.memberPrice} / £{tasting.data.guestPrice}
                    </div>
                    <div class="text-sm text-slate-500">member / guest</div>
                  </div>
                  <div class="text-right">
                    <div class="text-sm text-slate-500">
                      {tasting.data.maxAttendees} max attendees
                    </div>
                  </div>
                </div>

                {tasting.data.charity && (
                  <div class="mb-4 p-3 bg-green-50 rounded-lg">
                    <div class="text-sm font-medium text-green-800">Supporting:</div>
                    <div class="text-sm text-green-700">{tasting.data.charity}</div>
                  </div>
                )}
                
                <a href={`/tastings/${tasting.slug}`} class="block w-full text-center bg-wessex-red-500 text-white py-3 rounded-lg hover:bg-wessex-red-600 transition-colors font-medium">
                  Book Now
                </a>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-12 h-12 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a4 4 0 118 0v4m-4 14l-3-3m0 0l-3-3m3 3h12M5 21l3-3m0 0l3 3"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-slate-900 mb-2">New Tastings Coming Soon</h3>
          <p class="text-slate-600 mb-6">
            We're working with distilleries to bring you the next exceptional tasting experience. 
            Check back soon or join our membership for early access to new events.
          </p>
          <a href="/membership" class="inline-block bg-wessex-red-500 text-white px-6 py-2 rounded-lg hover:bg-wessex-red-600 transition-colors font-medium">
            Join for Early Access
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- Past Tastings (if any) -->
  {pastTastings.length > 0 && (
    <section class="py-16 bg-slate-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-wessex-navy-900 mb-4 font-serif">Past Tastings</h2>
          <p class="text-lg text-slate-600">
            A look back at our recent whisky experiences
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {pastTastings.slice(0, 6).map((tasting) => (
            <div class="bg-white rounded-lg shadow-md border border-slate-200 overflow-hidden opacity-75 hover:opacity-100 transition-opacity">
              {tasting.data.image && (
                <div class="aspect-w-16 aspect-h-9">
                  <img src={tasting.data.image} alt={tasting.data.title} class="w-full h-48 object-cover grayscale hover:grayscale-0 transition-all" />
                </div>
              )}
              <div class="p-6">
                <div class="flex justify-between items-start mb-3">
                  <h3 class="text-lg font-semibold text-slate-900">{tasting.data.title}</h3>
                  <span class="text-sm text-slate-500">
                    {tasting.data.date.toLocaleDateString('en-GB', { 
                      month: 'short',
                      year: 'numeric'
                    })}
                  </span>
                </div>
                
                {tasting.data.distillery && (
                  <p class="text-wessex-gold-600 font-medium text-sm mb-2">{tasting.data.distillery}</p>
                )}
                
                <p class="text-slate-600 text-sm line-clamp-2">{tasting.data.description}</p>
                
                {tasting.data.charity && (
                  <div class="mt-3 text-xs text-green-600">
                    <span class="font-medium">Supported:</span> {tasting.data.charity}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="py-16 bg-wessex-red-500">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 font-serif">
        Never Miss a Tasting
      </h2>
      <p class="text-xl text-wessex-red-100 mb-8 max-w-2xl mx-auto">
        Join our membership for priority booking, member pricing, and exclusive access to special events.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/membership" class="bg-white text-wessex-red-500 px-8 py-3 rounded-lg hover:bg-wessex-red-50 transition-colors font-semibold">
          Become a Member
        </a>
        <a href="/contact" class="border-2 border-white text-white px-8 py-3 rounded-lg hover:bg-white hover:text-wessex-red-500 transition-colors font-semibold">
          Stay Updated
        </a>
      </div>
    </div>
  </section>

</MainLayout>
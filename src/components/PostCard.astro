---
const { post } = Astro.props;
---

<article class="border border-slate-200 rounded-xl overflow-hidden hover:shadow-xl transition-shadow bg-white flex flex-col">
  <a href={`/blog/${post.slug}`} class="block">
    {post.data.image ? (
      <div class="relative">
        <img src={post.data.image} alt={post.data.title} class="w-full h-48 object-cover" />
        {post.data.distillery && (
          <span class="absolute top-3 left-3 bg-white/90 text-wessex-navy-800 px-3 py-1 rounded-full text-xs font-semibold border border-slate-200">
            {post.data.distillery}
          </span>
        )}
      </div>
    ) : null}
    <div class="p-5 space-y-3">
      <div class="flex justify-between items-start gap-3">
        <div>
          <h3 class="text-xl font-semibold text-wessex-navy-800 leading-snug">{post.data.title}</h3>
          <p class="text-sm text-slate-500">{new Date(post.data.date).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</p>
        </div>
        {post.data.rating !== undefined && (
          <div class="bg-wessex-gold-50 text-wessex-navy-800 text-xs font-semibold px-2.5 py-1 rounded-full border border-wessex-gold-200">
            {post.data.rating}/5
          </div>
        )}
      </div>

      <p class="text-slate-700 text-sm leading-relaxed">{post.data.excerpt}</p>

      {post.data.tags ? (
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((t) => (
            <span class="text-xs bg-wessex-gold-100 text-wessex-navy-700 px-2 py-1 rounded-full">{t}</span>
          ))}
        </div>
      ) : null}

      {post.data.stockists && post.data.stockists.length > 0 ? (
        <div class="pt-2 border-t border-slate-100">
          <p class="text-xs uppercase tracking-wide text-slate-500 mb-2">Stockists</p>
          <div class="flex flex-wrap gap-2">
            {post.data.stockists.slice(0, 2).map((s) => (
              <span class="inline-flex items-center gap-1 text-xs bg-slate-100 text-wessex-navy-700 px-2 py-1 rounded-full border border-slate-200">
                <svg class="w-3 h-3 text-wessex-red-500" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M10 2C6.13 2 3 5.13 3 9c0 4.17 5.8 9.36 6.05 9.59a1 1 0 001.35 0C11.2 18.36 17 13.17 17 9c0-3.87-3.13-7-7-7Zm0 10.5a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7Z" />
                </svg>
                <span>{s.name}</span>
                {s.affiliate ? <span class="text-[10px] text-wessex-red-600 font-semibold">Aff</span> : null}
              </span>
            ))}
          </div>
        </div>
      ) : null}
    </div>
  </a>
  <div class="px-5 pb-5 text-wessex-red-500 font-semibold inline-flex items-center">
    <span>Read tasting</span>
    <svg class="w-4 h-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 0 1 0-1.414L10.586 10 7.293 6.707a1 1 0 1 1 1.414-1.414l4 4a1 1 0 0 1 0 1.414l-4 4a1 1 0 0 1-1.414 0Z" clip-rule="evenodd" />
    </svg>
  </div>
</article>

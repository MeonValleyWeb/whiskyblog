<footer class="bg-wessex-navy-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Site Info -->
      <div class="col-span-1 md:col-span-2">
        <h3 class="text-2xl font-bold text-wessex-gold-400 mb-4 font-serif">Fat Pasty Blog</h3>
        <p class="text-slate-300 mb-4 max-w-md">
          Personal whisky writing: tasting notes, distillery visits, stockists and recommendations.
          Reviews and further reading to help you discover great drams.
        </p>
        <div class="flex space-x-4">
          <!-- Social Media Links -->
          <a href="#" class="text-slate-400 hover:text-wessex-gold-400 transition-colors">
            <span class="sr-only">Facebook</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" class="text-slate-400 hover:text-wessex-gold-400 transition-colors">
            <span class="sr-only">Instagram</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 6.62 5.367 11.987 11.988 11.987 6.62 0 11.987-5.367 11.987-11.987C24.014 5.367 18.637.001 12.017.001zM8.449 16.988c-1.297 0-2.448-.49-3.328-1.297L3.182 17.73l2.738-1.939c.85-.85 2.04-1.375 3.366-1.375 2.619 0 4.75 2.131 4.75 4.75s-2.131 4.75-4.75 4.75z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-lg font-semibold text-white mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li><a href="/blog" class="text-slate-300 hover:text-wessex-gold-400 transition-colors">Blog</a></li>
          <li><a href="/about" class="text-slate-300 hover:text-wessex-gold-400 transition-colors">About</a></li>
          <li><a href="/contact" class="text-slate-300 hover:text-wessex-gold-400 transition-colors">Contact</a></li>
          <li><a href="/subscribe" class="text-slate-300 hover:text-wessex-gold-400 transition-colors">Subscribe</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-lg font-semibold text-white mb-4">Contact</h4>
        <ul class="space-y-2 text-slate-300">
          <li>Email: hello@wessexwhisky.co.uk</li>
          <li>Based in the South West, writing from home tastings and distillery trips.</li>
          <li>
            <a href="/contact" class="text-wessex-gold-400 hover:text-wessex-gold-300 transition-colors">
              Get in Touch →
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-800 mt-8 pt-8 text-center text-slate-400">
      <p>&copy; {new Date().getFullYear()} Wessex Whisky. All rights reserved.</p>
      <p class="mt-2 text-sm">Personal whisky writing and reviews.</p>
    </div>
  </div>
</footer>

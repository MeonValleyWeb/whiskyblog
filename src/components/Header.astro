---
---

<header class="bg-white shadow-lg border-b border-wessex-gold-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center py-4">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="flex items-center">
          <img src="/wessex_whisky_logo_coloured.png" alt="Wessex Whisky" class="h-12 w-12 mr-3">
          <span class="text-2xl font-bold text-wessex-navy-700 hover:text-wessex-red-500 transition-colors">
            Fat Pasty
          </span>
        </a>
      </div>

      <!-- Navigation -->
      <nav class="hidden md:flex items-center space-x-8">
        <a href="/" class="text-wessex-navy-600 hover:text-wessex-red-500 transition-colors font-medium">Home</a>
        <a href="/blog" class="text-wessex-navy-600 hover:text-wessex-red-500 transition-colors font-medium">Blog</a>
        <a href="/guides" class="text-wessex-navy-600 hover:text-wessex-red-500 transition-colors font-medium">Guides</a>
        <a href="/about" class="text-wessex-navy-600 hover:text-wessex-red-500 transition-colors font-medium">About</a>
        <a href="/contact" class="text-wessex-navy-600 hover:text-wessex-red-500 transition-colors font-medium">Contact</a>
      </nav>

      <!-- CTA Button -->
      <div class="hidden md:flex">
        <a href="/subscribe" class="bg-wessex-red-500 text-white px-6 py-2 rounded-lg hover:bg-wessex-red-600 transition-colors font-medium">
          Subscribe
        </a>
      </div>

      <!-- Mobile menu button -->
      <button class="md:hidden p-2" id="mobile-menu-toggle">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <nav class="md:hidden pb-4 hidden" id="mobile-menu">
      <div class="flex flex-col space-y-4">
        <a href="/" class="text-wessex-navy-600 hover:text-wessex-red-500 transition-colors font-medium">Home</a>
        <a href="/blog" class="text-wessex-navy-600 hover:text-wessex-red-500 transition-colors font-medium">Blog</a>
        <a href="/guides" class="text-wessex-navy-600 hover:text-wessex-red-500 transition-colors font-medium">Guides</a>
        <a href="/about" class="text-wessex-navy-600 hover:text-wessex-red-500 transition-colors font-medium">About</a>
        <a href="/contact" class="text-wessex-navy-600 hover:text-wessex-red-500 transition-colors font-medium">Contact</a>
        <a href="/subscribe" class="bg-wessex-red-500 text-white px-6 py-2 rounded-lg hover:bg-wessex-red-600 transition-colors font-medium text-center">
          Subscribe
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  
  mobileMenuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
